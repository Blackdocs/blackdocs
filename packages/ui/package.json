{
  "name": "@blackdocs/ui",
  "version": "0.1.0",
  "description": "Blackdocs UI components",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./src/css/global.css"
  },
  "files": [
    "dist",
    "src/css"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "types:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@blackdocs/core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "scroll-into-view-if-needed": "^3.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@blackdocs/eslint-config": "workspace:*",
    "rimraf": "^6.1.3",
    "@blackdocs/typescript-config": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
