{
  "name": "@blackdocs/core",
  "version": "0.1.0",
  "description": "Blackdocs Core utilities and types",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "types:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/react": "^19.2.14",
    "@blackdocs/eslint-config": "workspace:*",
    "rimraf": "^6.1.3",
    "@blackdocs/typescript-config": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  }
}
