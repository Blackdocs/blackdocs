{
  "name": "@blackdocs/core",
  "version": "0.1.0",
  "description": "Blackdocs Core utilities and types",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./framework": {
      "types": "./dist/framework/index.d.ts",
      "import": "./dist/framework/index.js"
    },
    "./framework/next": {
      "types": "./dist/framework/next.d.ts",
      "import": "./dist/framework/next.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "types:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@blackdocs/eslint": "workspace:*",
    "@blackdocs/typescript": "workspace:*",
    "@types/node": "25.8.0",
    "@types/react": "^19.2.14",
    "next": "^16.2.6",
    "rimraf": "^6.1.3",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
